# このファイルを .env にコピーして値を設定する（.env は git 管理外）。
#   cp .env.example .env
# docker compose が同じディレクトリの .env を自動で読み込む。

# uvicorn のバインド先IP。
# 未設定なら 127.0.0.1（localhost のみ）。全インターフェースなら 0.0.0.0。
# 別コンテナの前段プロキシから届かせる場合は、そのプロキシから到達できる
# アドレス（docker ネットワークのゲートウェイIP等）を指定する。
PI_INFO_HOST=127.0.0.1

# 待ち受けポート
PI_INFO_PORT=8001
